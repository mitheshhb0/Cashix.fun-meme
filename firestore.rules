rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: approved_emails
    // Document ID: <email> (lowercase email string)
    // Fields:
    //   - approved: bool (required) - true if whitelist is approved
    //   - approvedAt: string (optional) - timestamp string
    //   - approvedBy: string (optional) - admin email who approved
    //
    // Collection: users
    // Document ID: <email> (lowercase email string)
    // Fields:
    //   - email: string (required) - lowercase email string
    //   - displayName: string (required) - user's display name
    //   - joinedDate: string (required) - date format (YYYY-MM-DD)
    //   - status: string (required) - "ACTIVE" | "SUSPENDED"
    //   - role: string (required) - "MEMBER" | "ADMIN"
    //
    // Collection: pending_signups
    // Document ID: <email> (lowercase email string)
    // Fields:
    //   - email: string (required) - lowercase email string
    //   - displayName: string (required) - user's display name
    //   - requestedAt: string (required) - ISO timestamp string
    //
    // Collection: signals
    // Document ID: active
    // Fields:
    //   - tokenName: string (required)
    //   - action: string (required) - "BUY" | "SELL"
    //   - contractAddress: string (required)
    //   - entryPrice: string (required)
    //   - targetPrice: string (required)
    //   - stopLoss: string (required)
    //   - rationale: string (required)
    //   - timestamp: string (required)
    //
    // Collection: announcements
    // Document ID: active
    // Fields:
    //   - message: string (required)
    //   - timestamp: string (required)
    //   - sender: string (required)
    //
    // Collection: audit_logs
    // Document ID: <auto-generated>
    // Fields:
    //   - action: string (required)
    //   - admin: string (required)
    //   - timestamp: string (required)
    //
    // Collection: chat_messages
    // Document ID: <auto-generated>
    // Fields:
    //   - user: string (required)
    //   - email: string (required)
    //   - message: string (required)
    //   - time: string (required)
    //   - isAdmin: bool (required)
    //   - timestamp: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is a registered Admin
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.lower() == 'admin@cashix.fun' || 
         request.auth.token.email.lower() == 'mitheshhb0@gmail.com');
    }

    // Check if the email scopes match the authenticated user
    function isOwnerEmail(email) {
      return isAuthenticated() && request.auth.token.email.lower() == email.lower();
    }

    // Ensure document contains only the allowed fields
    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    // Ensure document contains all required fields
    function hasRequiredFields(data, fields) {
      return data.keys().hasAll(fields);
    }

    // ===============================================================
    // Collection Match Rules
    // ===============================================================

    // Approved Emails / Whitelist
    match /approved_emails/{email} {
      allow read: if isAdmin() || isOwnerEmail(email);
      allow write: if isAdmin();
    }

    // Users Profiles
    match /users/{email} {
      allow read: if isAdmin() || isOwnerEmail(email);
      allow create: if isOwnerEmail(email) && 
        hasRequiredFields(request.resource.data, ['email', 'displayName', 'joinedDate', 'status', 'role']) &&
        hasOnlyAllowedFields(request.resource.data, ['email', 'displayName', 'joinedDate', 'status', 'role']) &&
        request.resource.data.email.lower() == email.lower() &&
        request.resource.data.role == 'MEMBER' && // New users cannot elevate their role to ADMIN
        request.resource.data.status == 'ACTIVE';
      allow update: if isAdmin() || (isOwnerEmail(email) &&
        hasRequiredFields(request.resource.data, ['email', 'displayName', 'joinedDate', 'status', 'role']) &&
        hasOnlyAllowedFields(request.resource.data, ['email', 'displayName', 'joinedDate', 'status', 'role']) &&
        request.resource.data.role == resource.data.role && // Cannot update own role
        request.resource.data.status == resource.data.status // Cannot update own status
      );
      allow delete: if isAdmin();
    }

    // Pending Signups Queue
    match /pending_signups/{email} {
      allow read: if isAdmin() || isOwnerEmail(email);
      allow create: if isOwnerEmail(email) &&
        hasRequiredFields(request.resource.data, ['email', 'displayName', 'requestedAt']) &&
        hasOnlyAllowedFields(request.resource.data, ['email', 'displayName', 'requestedAt']) &&
        request.resource.data.email.lower() == email.lower() &&
        request.resource.data.displayName.size() <= 50;
      allow delete: if isAdmin() || isOwnerEmail(email);
    }

    // Trading Intelligence Signals
    match /signals/{documentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Announcements
    match /announcements/{documentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Admin Audit Logs
    match /audit_logs/{documentId} {
      allow read, write: if isAdmin();
    }

    // Trading Floor Chat Messages
    match /chat_messages/{documentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        hasRequiredFields(request.resource.data, ['user', 'email', 'message', 'time', 'isAdmin', 'timestamp']) &&
        hasOnlyAllowedFields(request.resource.data, ['user', 'email', 'message', 'time', 'isAdmin', 'timestamp']) &&
        request.resource.data.email.lower() == request.auth.token.email.lower() &&
        request.resource.data.message.size() <= 500 && // Protect against huge text DoS attacks
        (request.resource.data.isAdmin == false || isAdmin()); // Users cannot fake admin badge
      allow update, delete: if isAdmin();
    }
  }
}
